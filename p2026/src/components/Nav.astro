---
const activeRoute = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const homeHref = base || '/';

function isActive(path: string) {
  const current = activeRoute.replace(/\/+$/, '') || '/';
  const target = path.replace(/\/+$/, '') || '/';
  if (target === '/') return current === '/';
  return current === target || current.startsWith(`${target}/`);
}
---

<nav>
  <a href={homeHref} class="nav-logo">P<span>2026</span></a>
  <div class="nav-right">
    <ul class="nav-links">
      <li><a href={`${base}/blog`} class={isActive(`${base}/blog`) ? 'active' : ''}>Writing</a></li>
      <li><a href={`${base}/projects`} class={isActive(`${base}/projects`) ? 'active' : ''}>Projects</a></li>
      <li><a href={`${base}/resources`} class={isActive(`${base}/resources`) ? 'active' : ''}>Resources</a></li>
      <li><a href={`${base}/about`} class={isActive(`${base}/about`) ? 'active' : ''}>About</a></li>
    </ul>
    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open navigation menu">☰</button>
    <button class="theme-btn" id="themeToggle" aria-label="Toggle light and dark theme">◑</button>
  </div>
</nav>

<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
  <a href={`${base}/blog`} class={isActive(`${base}/blog`) ? 'active' : ''}>Writing</a>
  <a href={`${base}/projects`} class={isActive(`${base}/projects`) ? 'active' : ''}>Projects</a>
  <a href={`${base}/resources`} class={isActive(`${base}/resources`) ? 'active' : ''}>Resources</a>
  <a href={`${base}/about`} class={isActive(`${base}/about`) ? 'active' : ''}>About</a>
</nav>

<script lang="ts">
  const btn = document.getElementById('themeToggle') as HTMLButtonElement | null;
  const root = document.documentElement;

  btn?.addEventListener('click', () => {
    const dark = root.getAttribute('data-theme') === 'dark';
    root.setAttribute('data-theme', dark ? 'light' : 'dark');
    try { localStorage.setItem('theme', dark ? 'light' : 'dark'); } catch {}
  });

  const menuBtn = document.getElementById('mobileMenuBtn') as HTMLButtonElement | null;
  const mobileNav = document.getElementById('mobileNav') as HTMLElement | null;

  menuBtn?.addEventListener('click', () => {
    if (mobileNav && menuBtn) {
      const open = mobileNav.classList.toggle('open');
      menuBtn.setAttribute('aria-expanded', String(open));
      menuBtn.textContent = open ? '✕' : '☰';
    }
  });
</script>