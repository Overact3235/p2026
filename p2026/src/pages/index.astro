---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const shippedProjects = projects.filter((project) => project.data.status === 'shipped');

function formatPostDate(date: Date) {
  const parts = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).split(', ');
  // parts[0] is "Feb 28", parts[1] is "2026"
  return `${parts[0]}<br>${parts[1]}`;
}
---

<BaseLayout title="Home" description="Project 2026 — personal tech log and project hub.">
  <header class="hero">
    <div class="hero-content">
      <p class="hero-label">Project-2026</p>
      <h1>Something shipped.<br>Something broken.<br><em>Something learned.</em></h1>
      <p class="hero-sub">A public dev log by a software engineer who documents everything. Self-hosting, networking, and the tools I ship — written as I build.</p>
      <div class="hero-meta">
        <div class="hero-stat">
          <span class="hero-stat-num">{posts.length}</span>
          <span class="hero-stat-label">Posts</span>
        </div>
        <div class="hero-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">{projects.length}</span>
          <span class="hero-stat-label">Projects</span>
        </div>
        <div class="hero-divider"></div>
        <span class="status-pill">
          <span class="status-dot"></span>
          {shippedProjects.length > 0 ? `Shipped: ${shippedProjects[0].data.name}` : `Shipped: P2026`}
        </span>
      </div>
      <div class="cta-strip">
        <a href="/rss.xml" class="cta-rss" aria-label="Subscribe via RSS feed">⊕ Subscribe via RSS</a>
        <a href="/about" class="cta-about">About the builder →</a>
      </div>
    </div>

    <!-- ASCII ACCENT -->
    <div class="ascii-block" aria-hidden="true">┌─────────────┐
│ P2026       │
│ ░░░░░░░░░░░ │
│ ship · log  │
│ build · doc │
└─────────────┘</div>
  </header>

  <main class="content">
    <section class="section">
      <div class="section-header reveal">
        <h2 class="section-title">Recent blog posts</h2>
        <a href="/blog" class="section-link">All posts →</a>
      </div>
      <div class="post-list">
        {posts.map(post => (
          <a class="post-row reveal" href={`/blog/${post.slug}`}>
            <span class="post-date" set:html={formatPostDate(post.data.pubDate)}></span>
            <div class="post-info">
              <p class="post-title">{post.data.title}</p>
              <p class="post-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="section-header reveal">
        <h2 class="section-title">Projects</h2>
        <a href="/projects" class="section-link">All projects →</a>
      </div>
      <div class="project-list">
        {projects.map(project => (
          <a class="project-row reveal" href={`/projects/${project.slug}`}>
            <div class="project-left">
              <p class="project-name">{project.data.name}</p>
              <p class="project-desc">{project.data.description}</p>
            </div>
            <div class="project-right">
              <span class={`badge badge-${project.data.status}`}>{project.data.status.replace(/^\w/, (c: string) => c.toUpperCase())}</span>
              {project.data.metric && <span class="project-metric">{project.data.metric}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
