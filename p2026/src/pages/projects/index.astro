---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const shippedProjects = projects.filter(p => p.data.status === 'shipped');
const buildingProjects = projects.filter(p => p.data.status === 'building');
const archivedProjects = projects.filter(p => p.data.status === 'archived');
---

<BaseLayout title="Projects" description="A comprehensive list of projects, launches, and infrastructure.">
  <div class="content">
    <div class="page-header" style="margin-top: 3rem; margin-bottom: 3rem;">
      <span class="label">// all-projects</span>
      <h1>Projects</h1>
      <p style="color: var(--ink-muted); font-size: 0.975rem; max-width: 48ch;">Projects get a stable home here, with launches, notes, and related writing connected around them.</p>
    </div>

    <div class="project-filters" aria-label="Filter projects by status">
      <button type="button" class="project-filter-btn is-active" data-project-filter="all">All</button>
      <button type="button" class="project-filter-btn" data-project-filter="shipped">Shipped</button>
      <button type="button" class="project-filter-btn" data-project-filter="building">Building</button>
      <button type="button" class="project-filter-btn" data-project-filter="archived">Archived</button>
    </div>

    {shippedProjects.length > 0 && (
      <section class="section" data-project-group="shipped">
        <div class="section-header reveal">
          <h2 class="section-title">Shipped</h2>
        </div>
        <div class="project-list">
          {shippedProjects.map(project => (
            <a class="project-row reveal" href={`/projects/${project.slug}`}>
              <div class="project-left">
                <p class="project-name">{project.data.name}</p>
                <p class="project-desc">{project.data.description}</p>
              </div>
              <div class="project-right">
                <span class={`badge badge-${project.data.status}`}>{project.data.status.replace(/^\w/, c => c.toUpperCase())}</span>
                {project.data.metric && <span class="project-metric">{project.data.metric}</span>}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {buildingProjects.length > 0 && (
      <section class="section" data-project-group="building">
        <div class="section-header reveal">
          <h2 class="section-title">Building</h2>
        </div>
        <div class="project-list">
          {buildingProjects.map(project => (
            <a class="project-row reveal" href={`/projects/${project.slug}`}>
              <div class="project-left">
                <p class="project-name">{project.data.name}</p>
                <p class="project-desc">{project.data.description}</p>
              </div>
              <div class="project-right">
                <span class={`badge badge-${project.data.status}`}>{project.data.status.replace(/^\w/, c => c.toUpperCase())}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
    
    {archivedProjects.length > 0 && (
      <section class="section" data-project-group="archived">
        <div class="section-header reveal">
          <h2 class="section-title">Archived</h2>
        </div>
        <div class="project-list">
          {archivedProjects.map(project => (
            <a class="project-row reveal" href={`/projects/${project.slug}`}>
              <div class="project-left">
                <p class="project-name">{project.data.name}</p>
                <p class="project-desc">{project.data.description}</p>
              </div>
              <div class="project-right">
                <span class={`badge badge-${project.data.status}`}>{project.data.status.replace(/^\w/, c => c.toUpperCase())}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<script>
  const filterButtons = Array.from(document.querySelectorAll('[data-project-filter]'));
  const groups = Array.from(document.querySelectorAll('[data-project-group]'));

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.getAttribute('data-project-filter');
      if (!filter) return;

      filterButtons.forEach((item) => {
        item.classList.toggle('is-active', item === button);
      });

      groups.forEach((group) => {
        const matches = filter === 'all' || group.getAttribute('data-project-group') === filter;
        group.toggleAttribute('hidden', !matches);
      });
    });
  });
</script>

<style>
  .project-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }

  .project-filter-btn {
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--ink-muted);
    font-family: var(--mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .project-filter-btn:hover,
  .project-filter-btn:focus-visible,
  .project-filter-btn.is-active {
    color: var(--amber);
    border-color: var(--amber);
    background: var(--amber-dim);
  }
</style>
