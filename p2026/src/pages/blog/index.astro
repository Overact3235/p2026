---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatPostDate(date: Date) {
  const parts = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).split(', ');
  return `${parts[0]}<br>${parts[1] ?? ''}`;
}
---

<BaseLayout title="Blog" description="All posts — project logs, thoughts, and writeups.">
  <div class="content">
    <div class="page-header" style="margin-top: 3rem; margin-bottom: 2rem;">
      <span class="hero-label">// blog</span>
      <h1 style="margin-top: 1rem; margin-bottom: 1rem;">Blog</h1>
      <p class="hero-sub" style="margin-bottom: 0;">Project logs, thoughts, and occasional deep dives. {posts.length} entries so far.</p>
    </div>

    <div class="post-list">
      {posts.map(post => (
        <a class="post-row" href={`/blog/${post.slug}`}>
          <span class="post-date" set:html={formatPostDate(post.data.pubDate)}></span>
          <div class="post-info">
            <p class="post-title">{post.data.title}</p>
            <p class="post-desc">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="post-card-tags" style="margin-top: 0.35rem; display:flex; gap:0.4rem; flex-wrap:wrap;">
                {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
