---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<BaseLayout title="About" description="The builder behind P2026. Web development, self-hosting, and tooling experiments documented in public.">
  <header class="hero">
    <div class="hero-content">
      <p class="hero-label">About</p>
      <h1>The builder<br>behind <em>P2026.</em></h1>
      <p class="hero-sub">Building in public through web development, self-hosting, and the small systems that make projects easier to run. Anonymous by choice.</p>
      <div class="cv-actions">
        <a href="https://github.com/Overact3235/p2026" class="btn-secondary" target="_blank" rel="noopener" aria-label="Open the P2026 repository on GitHub">View source ↗</a>
        <a href="mailto:contact@p2026.xyz" class="btn-secondary" aria-label="Email contact@p2026.xyz">Email</a>
        <!-- <a href="https://linkedin.com" class="btn-secondary" target="_blank" rel="noopener" aria-label="LinkedIn profile (opens in new tab)">LinkedIn ↗</a> -->
      </div>
    </div>
  </header>

  <main class="content">

    <!-- SKILLS -->
    <section class="section" aria-labelledby="skills-heading">
      <div class="section-header reveal">
        <h2 class="section-title" id="skills-heading">Skills & Stack</h2>
      </div>

      <div class="skill-row hover-row reveal">
        <span class="skill-label">Languages</span>
        <div class="skill-tags">
          <span class="skill-tag">HTML</span>
          <span class="skill-tag">CSS</span>
          <span class="skill-tag">TypeScript</span>
          <span class="skill-tag">JavaScript</span>
          <span class="skill-tag">Markdown / MDX</span>
        </div>
      </div>

      <div class="skill-row hover-row reveal">
        <span class="skill-label">Site stack</span>
        <div class="skill-tags">
          <span class="skill-tag">Astro 5</span>
          <span class="skill-tag">Node.js</span>
          <span class="skill-tag">Content Collections</span>
          <span class="skill-tag">GitHub Pages</span>
          <span class="skill-tag">RSS</span>
        </div>
      </div>

      <div class="skill-row hover-row reveal">
        <span class="skill-label">Infrastructure</span>
        <div class="skill-tags">
          <span class="skill-tag">Caddy</span>
          <span class="skill-tag">Nginx</span>
          <span class="skill-tag">Docker</span>
          <span class="skill-tag">Podman</span>
          <span class="skill-tag">Linux</span>
        </div>
      </div>

      <div class="skill-row hover-row reveal">
        <span class="skill-label">Tools</span>
        <div class="skill-tags">
          <span class="skill-tag">Git</span>
          <span class="skill-tag">GitHub Actions</span>
          <span class="skill-tag">n8n</span>
          <span class="skill-tag">VS Code</span>
          <span class="skill-tag">Lighthouse CI</span>
        </div>
      </div>
    </section>

    <!-- CURRENT FOCUS -->
    <section class="section" aria-labelledby="experience-heading">
      <div class="section-header reveal">
        <h2 class="section-title" id="experience-heading">Current Focus</h2>
      </div>

      <div class="exp-row hover-row reveal">
        <div class="exp-period">
          <span class="year">Now</span>
          Web
        </div>
        <div class="exp-body">
          <p class="exp-role">Website stack</p>
          <p class="exp-company">P2026</p>
          <p class="exp-desc">This site is built close to the platform: Astro, content collections, static output, and plain CSS with only the JavaScript that earns its keep.</p>
          <div class="exp-tags">
            <span class="exp-tag">Astro</span>
            <span class="exp-tag">TypeScript</span>
            <span class="exp-tag">JavaScript</span>
            <span class="exp-tag">HTML</span>
            <span class="exp-tag">CSS</span>
          </div>
        </div>
      </div>

      <div class="exp-row hover-row reveal">
        <div class="exp-period">
          <span class="year">Ops</span>
          Infra
        </div>
        <div class="exp-body">
          <p class="exp-role">Self-hosting and containers</p>
          <p class="exp-company">Homelab / side projects</p>
          <p class="exp-desc">Most of the learning happens around reverse proxies, containers, Linux hosts, and making services easy to ship, recover, and move around.</p>
          <div class="exp-tags">
            <span class="exp-tag">Caddy</span>
            <span class="exp-tag">Nginx</span>
            <span class="exp-tag">Docker</span>
            <span class="exp-tag">Podman</span>
            <span class="exp-tag">Linux</span>
          </div>
        </div>
      </div>

      <div class="exp-row hover-row reveal">
        <div class="exp-period">
          <span class="year">Flow</span>
          Tools
        </div>
        <div class="exp-body">
          <p class="exp-role">Automation and delivery</p>
          <p class="exp-company">Build and publish workflow</p>
          <p class="exp-desc">Git keeps the work trackable, GitHub Actions handles deploys, GitHub Pages ships the static site, and n8n fills in the automation gaps elsewhere.</p>
          <div class="exp-tags">
            <span class="exp-tag">Git</span>
            <span class="exp-tag">GitHub Actions</span>
            <span class="exp-tag">GitHub Pages</span>
            <span class="exp-tag">n8n</span>
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECTS -->
    <section class="section" aria-labelledby="projects-heading">
      <div class="section-header reveal">
        <h2 class="section-title" id="projects-heading">Projects</h2>
      </div>

      {projects.map(project => (
        <a class="project-row hover-row reveal" href={project.data.link || `/projects/${project.slug}`}>
          <div class="project-left">
            <p class="project-name">{project.data.name}</p>
            <p class="project-desc">{project.data.description}</p>
          </div>
          <div class="project-right">
            <span class={`badge badge-${project.data.status}`}>{project.data.status.replace(/^\w/, (c: string) => c.toUpperCase())}</span>
            {project.data.metric && <span class="project-metric">{project.data.metric}</span>}
          </div>
        </a>
      ))}
    </section>

    <!-- CONTACT -->
    <section class="section" aria-labelledby="contact-heading">
      <div class="section-header reveal">
        <h2 class="section-title" id="contact-heading">Contact</h2>
      </div>

      <a href="https://github.com/Overact3235/p2026" class="contact-row hover-row reveal" target="_blank" rel="noopener">
        <span class="contact-label">GitHub</span>
        <span class="contact-value">github.com</span>
      </a>

      <!--
      <a href="https://linkedin.com" class="contact-row hover-row reveal" target="_blank" rel="noopener">
        <span class="contact-label">LinkedIn</span>
        <span class="contact-value">linkedin.com/in/...</span>
      </a>
      -->

      <a href="mailto:contact@p2026.xyz" class="contact-row hover-row reveal">
        <span class="contact-label">Email</span>
        <span class="contact-value">contact@p2026.xyz</span>
      </a>
    </section>

  </main>
</BaseLayout>
