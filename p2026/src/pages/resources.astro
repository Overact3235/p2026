---
import BaseLayout from '../layouts/BaseLayout.astro';

const resources = [
  {
    category: 'My Sites',
    items: [
      { name: 'P2026', desc: '(This site!) Main site for project logs and build notes.', url: 'https://p2026.xyz' },
      { name: 'MC Endpoint', desc: 'Minecraft server endpoint for private sessions.', url: 'https://mc.p2026.xyz' },
    ],
  },
  {
    category: 'Frameworks & Tools',
    items: [
      { name: 'Astro', desc: 'Static site framework — what this site is built on.', url: 'https://astro.build' },
    ],
  },
  {
    category: 'Deployment & Infra',
    items: [
      { name: 'GitHub Pages', desc: 'Free static hosting directly from a repo.', url: 'https://pages.github.com' },
    ],
  },
  {
    category: 'Cheatsheets',
    items: [
      { name: 'DevHints', desc: 'Cheatsheets for commands, tools, and languages.', url: 'https://devhints.io' },
      { name: 'DevSheets', desc: 'Quick reference sheets for developers.', url: 'https://www.devsheets.io' },
    ],
  },
];
---

<BaseLayout title="Resources" description="Tools, cheatsheets, and references I keep coming back to.">
  <div class="content">
    <div class="page-header" style="margin-top: 3rem; margin-bottom: 2rem;">
      <span class="hero-label">// resources</span>
      <h1 style="margin-top: 1rem; margin-bottom: 1rem;">Resources</h1>
      <p class="hero-sub" style="margin-bottom: 0;">Tools, cheatsheets, and links I keep coming back to. Curated, not exhaustive.</p>
    </div>

    {resources.map(group => (
      <section class="section">
        <div class="section-header">
          <h2 class="section-title">{group.category}</h2>
        </div>
        {group.items.map(item => (
          <div class="project-row">
            <div class="project-left">
              <a href={item.url} target="_blank" rel="noopener" class="project-name" style="text-decoration:none;">{item.name}</a>
              <p class="project-desc">{item.desc}</p>
            </div>
            <div class="project-right">
              <a href={item.url} target="_blank" rel="noopener" class="badge" style="color:var(--ink-faint); text-decoration:none; letter-spacing:0.06em;">
                {new URL(item.url).hostname.replace('www.', '')} ↗
              </a>
            </div>
          </div>
        ))}
      </section>
    ))}
  </div>
</BaseLayout>
